{
	"name": "frontend-st",
	"version": "1.0.0",
	"description": "",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"biome:check": "biome check .",
		"biome:write": "biome check --write .",
		"check": "biome check .",
		"fix": "biome check --write .",
		"html:check": "prettier --check \"index.html\" --no-error-on-unmatched-pattern",
		"html:format": "prettier --write \"index.html\" --no-error-on-unmatched-pattern",
		"styles:lint": "stylelint \"src/**/*.{css,scss,sass}\" --custom-syntax postcss-scss --allow-empty-input",
		"styles:fix": "stylelint \"src/**/*.{css,scss,sass}\" --custom-syntax postcss-scss --fix --allow-empty-input",
		"check:all": "npm run biome:check && npm run styles:lint && npm run html:check",
		"fix:all": "npm run biome:write && npm run styles:fix && npm run html:format",
		"lint": "npm run biome:check && npm run styles:lint && npm run html:check",
		"format": "npm run biome:write && npm run styles:fix && npm run html:format",
		"lint-staged": "lint-staged"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SaludTotal-Ucb/Frontend-ST.git"
	},
	"keywords": [
		"react",
		"vite",
		"tailwindcss"
	],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/SaludTotal-Ucb/Frontend-ST/issues"
	},
	"homepage": "https://github.com/SaludTotal-Ucb/Frontend-ST#readme",
	"lint-staged": {
		"**/*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": "biome check --write",
		"**/*.html": "prettier --write --no-error-on-unmatched-pattern",
		"**/*.{css,scss,sass}": "stylelint --fix --custom-syntax postcss-scss"
	},
	"dependencies": {
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-menubar": "^1.1.16",
		"@radix-ui/react-navigation-menu": "^1.2.14",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"embla-carousel": "^8.6.0",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.7.0",
		"next-themes": "^0.4.6",
		"react": "^18.3.1",
		"react-day-picker": "^9.14.0",
		"react-dom": "^18.3.1",
		"react-hook-form": "^7.72.0",
		"react-resizable-panels": "^4.7.6",
		"react-router": "^7.13.2",
		"recharts": "^3.8.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.4.1",
		"autoprefixer": "^10.4.21",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.3",
		"postcss": "^8.5.6",
		"postcss-scss": "^4.0.9",
		"prettier": "^3.8.1",
		"stylelint": "^17.4.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"tailwindcss": "^3.4.17",
		"vite": "^5.4.19"
	}
}
